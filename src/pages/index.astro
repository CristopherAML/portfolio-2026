---
import "../styles/global.css";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>cristopher-aml-dev</title>
    <meta name="description" content="Portafolio de Cristopher Meza — Ingeniero especializado en backend de alto rendimiento, data engineering con Polars y despliegues en Linux." />
  </head>

  <body
    class="bg-black text-green-500 font-mono min-h-screen flex flex-col overflow-x-hidden selection:bg-green-900 selection:text-green-100"
  >
    <div class="crt-overlay"></div>

    <div
      id="terminal-container"
      class="h-screen w-full flex flex-col p-6 transition-opacity duration-700 ease-in-out"
    >
      <div
        id="terminal-screen"
        class="flex flex-col gap-2 text-sm md:text-base"
      >
      </div>
      <p
        id="cursor"
        class="animate-pulse mt-2 text-green-500 text-lg font-bold"
      >
        _
      </p>
    </div>

    <div
      id="portfolio-container"
      class="hidden min-h-screen w-full p-8 md:p-16 text-gray-300 opacity-0 transition-opacity duration-1000 ease-in-out max-w-6xl mx-auto"
    >
      <div class="flex justify-end w-full mb-4">
        <button
          id="lang-switch"
          class="font-mono border border-green-500/50 px-3 py-1 text-[10px] md:text-xs text-green-500 hover:bg-green-500 hover:text-black transition-all shadow-[0_0_10px_rgba(34,197,94,0.1)]"
        >
          [ SWITCH_LANG: EN ]
        </button>
      </div>

      <header class="mb-20 mt-10 animate-fade-in-up">
        <div
          class="flex flex-col md:flex-row md:items-center md:justify-between gap-10"
        >
          <div class="flex-1 order-2 md:order-1">
            <p class="text-green-500 mb-4 font-mono text-sm">
              ///// DATA_PIPELINES: ACTIVE // SYS_READY
            </p>
            <h1
              class="text-5xl md:text-7xl font-bold tracking-tighter mb-4 glitch-hover group"
              data-text="CRISTOPHER MEZA"
            >
              <span class="text-white">CRISTOPHER</span>
              <span class="text-green-500">MEZA</span>
            </h1>
            <p
              data-i18n="heroText"
              class="max-w-3xl text-lg text-gray-400 leading-relaxed mb-6"
            >
              Ingeniero especializado en el desarrollo de <span
                class="text-green-500">sistemas integrales</span
              >, desde arquitecturas backend de alto rendimiento hasta
              interfaces dinámicas y funcionales. Experto en optimización de
              datos y en la creación de herramientas de gestión, integrando
              flujos de asistencia y despliegues robustos en Linux con un
              enfoque en la seguridad y la experiencia del usuario.
            </p>
            <a
              href="/cv_cristopher_meza.pdf"
              target="_blank"
              rel="noopener noreferrer"
              class="mt-8 inline-flex items-center gap-2 border border-green-500 bg-green-500/10 px-6 py-3 hover:bg-green-500 hover:text-black transition-all duration-300 font-mono text-sm tracking-widest uppercase shadow-[0_0_10px_rgba(74,222,128,0.2)] hover:shadow-[0_0_20px_rgba(74,222,128,0.5)]"
            >
              <span data-i18n="cvBtn">[ EXTRAER_REGISTRO_CV.pdf ]</span>
            </a>
          </div>

          <div
            class="flex-shrink-0 order-1 md:order-2 flex justify-center md:justify-end"
          >
            <div
              class="glitch-image-hover relative size-40 md:size-48 rounded-full border-2 border-green-500/50 overflow-hidden shadow-[0_0_15px_rgba(74,222,128,0.2)]"
              style="--glitch-img: url('/yo.jpeg');"
            >
              <img
                src="/yo.jpeg"
                alt="Cristopher Meza"
                class="w-full h-full object-cover rounded-full"
              />
            </div>
          </div>
        </div>
      </header>

      <div
        class="relative w-full bg-green-500/5 border-y border-green-500/20 py-2 overflow-hidden whitespace-nowrap mb-16"
      >
        <div
          class="inline-block animate-marquee font-mono text-[10px] md:text-xs text-green-500/60 tracking-[0.2em] uppercase"
        >
          <span data-i18n="ticker" aria-hidden="true"
            >RENDIMIENTO POLARS: +400% vs PANDAS &nbsp;&nbsp;&nbsp; //
            &nbsp;&nbsp;&nbsp; > REGISTROS PROCESADOS: +2.5M &nbsp;&nbsp;&nbsp;
            // &nbsp;&nbsp;&nbsp; > STATUS: SYSTEM_OPTIMIZED &nbsp;&nbsp;&nbsp;
            // &nbsp;&nbsp;&nbsp; > ARCHITECTURE: DISTRIBUTED &nbsp;&nbsp;&nbsp;
            // &nbsp;&nbsp;&nbsp; > COMPLIANCE: SONIC_SCIENTIST_ACTIVE
            &nbsp;&nbsp;&nbsp; // &nbsp;&nbsp;&nbsp; > LOCATION: CDMX_NODE
            &nbsp;&nbsp;&nbsp; // &nbsp;&nbsp;&nbsp;
          </span><span data-i18n="ticker"
            >RENDIMIENTO POLARS: +400% vs PANDAS &nbsp;&nbsp;&nbsp; //
            &nbsp;&nbsp;&nbsp; > REGISTROS PROCESADOS: +2.5M &nbsp;&nbsp;&nbsp;
            // &nbsp;&nbsp;&nbsp; > STATUS: SYSTEM_OPTIMIZED &nbsp;&nbsp;&nbsp;
            // &nbsp;&nbsp;&nbsp; > ARCHITECTURE: DISTRIBUTED &nbsp;&nbsp;&nbsp;
            // &nbsp;&nbsp;&nbsp; > COMPLIANCE: SONIC_SCIENTIST_ACTIVE
            &nbsp;&nbsp;&nbsp; // &nbsp;&nbsp;&nbsp; > LOCATION: CDMX_NODE
            &nbsp;&nbsp;&nbsp; // &nbsp;&nbsp;&nbsp;
          </span>
        </div>
      </div>
      <section>
        <h3
          data-i18n="modulesTitle"
          class="text-2xl font-bold text-white mb-8 border-b border-green-500/30 pb-4 inline-block pr-10 glitch-hover transition-colors duration-200 cursor-default"
        >
          > módulos_desplegados
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <div
            class="relative border border-green-500/20 bg-gray-900 overflow-hidden hover:border-green-500 transition-all duration-300 group p-6"
          >
            <div
              class="absolute inset-0 bg-[url('/circuitos.jpg')] bg-cover bg-center opacity-10 mix-blend-overlay group-hover:opacity-25 transition-opacity duration-500"
            >
            </div>
            <div class="relative z-10">
              <div class="mb-3">
                <h4 class="text-green-400 font-bold text-xl group-hover:text-green-300 transition-colors">
                  Sonic Scientist
                </h4>
                <span data-i18n="wipBadge" class="inline-block mt-1 text-[10px] font-mono text-yellow-500/70 border border-yellow-500/30 px-2 py-0.5">[ EN DESARROLLO ]</span>
              </div>
              <p
                data-i18n="sonicDesc"
                class="text-sm text-gray-400 mb-6 line-clamp-3"
              >
                Herramienta de cumplimiento normativo y auditoría. Desarrollo
                enfocado en la validación estructurada de datos y la aplicación
                estricta de filtros regulatorios.
              </p>
              <div
                class="flex flex-wrap gap-2 text-xs font-mono text-green-600/80"
              >
                <span
                  class="bg-green-500/10 px-2 py-1 border border-green-500/20"
                  >Python</span
                >
                <span
                  class="bg-green-500/10 px-2 py-1 border border-green-500/20"
                  >Polars</span
                >
                <span
                  class="bg-green-500/10 px-2 py-1 border border-green-500/20"
                  >Data Validation</span
                >
              </div>
            </div>
          </div>

          <div
            class="border border-green-500/20 bg-gray-900/40 p-6 hover:border-green-500 hover:bg-green-900/10 transition-all duration-300 group"
          >
            <div class="mb-3">
              <h4 class="text-green-400 font-bold text-xl group-hover:text-green-300">
                DocHub
              </h4>
              <span data-i18n="wipBadge" class="inline-block mt-1 text-[10px] font-mono text-yellow-500/70 border border-yellow-500/30 px-2 py-0.5">[ EN DESARROLLO ]</span>
            </div>
            <p
              data-i18n="dochubDesc"
              class="text-sm text-gray-400 mb-6 line-clamp-3"
            >
              Sistema integral de gestión de archivos. Arquitectura diseñada
              para el despliegue seguro en servidores, optimizando el flujo de
              trabajo y repositorios.
            </p>
            <div
              class="flex flex-wrap gap-2 text-xs font-mono text-green-600/80"
            >
              <span class="bg-green-500/10 px-2 py-1 border border-green-500/20"
                >Linux</span
              >
              <span class="bg-green-500/10 px-2 py-1 border border-green-500/20"
                >Backend Arch</span
              >
              <span class="bg-green-500/10 px-2 py-1 border border-green-500/20"
                >Server Deploy</span
              >
            </div>
          </div>

          <div
            class="border border-green-500/20 bg-gray-900/40 p-6 hover:border-green-500 hover:bg-green-900/10 transition-all duration-300 group"
          >
            <div class="mb-3">
              <h4 class="text-green-400 font-bold text-xl group-hover:text-green-300">
                Dead Man's Switch
              </h4>
              <span data-i18n="wipBadge" class="inline-block mt-1 text-[10px] font-mono text-yellow-500/70 border border-yellow-500/30 px-2 py-0.5">[ EN DESARROLLO ]</span>
            </div>
            <p
              data-i18n="deadmanDesc"
              class="text-sm text-gray-400 mb-6 line-clamp-3"
            >
              Script de seguridad automatizado a nivel de sistema operativo para
              proteger y gestionar información crítica en caso de ausencias
              prolongadas.
            </p>
            <div
              class="flex flex-wrap gap-2 text-xs font-mono text-green-600/80"
            >
              <span class="bg-green-500/10 px-2 py-1 border border-green-500/20"
                >Bash</span
              >
              <span class="bg-green-500/10 px-2 py-1 border border-green-500/20"
                >Cybersecurity</span
              >
              <span class="bg-green-500/10 px-2 py-1 border border-green-500/20"
                >Automation</span
              >
            </div>
          </div>
        </div>
      </section>

      <section class="mt-20">
        <h3
          data-i18n="expTitle"
          class="text-2xl font-bold text-white mb-8 border-b border-green-500/30 pb-4 inline-block pr-10 glitch-hover transition-colors duration-200 cursor-default"
        >
          > experiencia_laboral
        </h3>

        <div class="flex flex-col">
          <!-- CNBV -->
          <div class="relative pl-8 border-l border-green-500/20 pb-10 group/job hover:border-green-500/50 transition-colors duration-300">
            <div class="absolute left-[-5px] top-1.5 w-2.5 h-2.5 rounded-full bg-black border-2 border-green-500 group-hover/job:bg-green-500 transition-colors duration-300"></div>
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-1 mb-3">
              <div>
                <h4 data-i18n="exp1Title" class="text-white font-bold text-base">Administrador de BD y Backend Developer</h4>
                <p class="text-green-500 text-sm font-mono">CNBV — Comisión Nacional Bancaria y de Valores</p>
              </div>
              <span class="text-xs text-gray-500 font-mono whitespace-nowrap border border-green-500/20 px-2 py-0.5 h-max">Mayo 2025 — <span data-i18n="expCurrent">Actualmente</span></span>
            </div>
            <ul data-i18n="exp1Bullets" class="text-sm text-gray-400 flex flex-col gap-1.5">
              <li><span class="text-green-500/50 mr-2">></span>Detección y depuración de inconsistencias en bases de datos críticas para supervisión financiera.</li>
              <li><span class="text-green-500/50 mr-2">></span>Automatización de procesos y cruce masivo de datos con SQL avanzado y scripts de backend.</li>
              <li><span class="text-green-500/50 mr-2">></span>Control de versiones de flujos de datos y automatizaciones con Git.</li>
            </ul>
          </div>

          <!-- RYR Protection -->
          <div class="relative pl-8 border-l border-green-500/20 pb-10 group/job hover:border-green-500/50 transition-colors duration-300">
            <div class="absolute left-[-5px] top-1.5 w-2.5 h-2.5 rounded-full bg-black border-2 border-green-500/50 group-hover/job:bg-green-500 group-hover/job:border-green-500 transition-colors duration-300"></div>
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-1 mb-3">
              <div>
                <h4 data-i18n="exp2Title" class="text-white font-bold text-base">Desarrollador Full Stack (React / Node.js)</h4>
                <p class="text-green-500 text-sm font-mono">RYR Protection</p>
              </div>
              <span class="text-xs text-gray-500 font-mono whitespace-nowrap border border-green-500/20 px-2 py-0.5 h-max">Ene 2025 — May 2025</span>
            </div>
            <ul data-i18n="exp2Bullets" class="text-sm text-gray-400 flex flex-col gap-1.5">
              <li><span class="text-green-500/50 mr-2">></span>Desarrollo y mantenimiento de aplicaciones web corporativas con React y Node.js.</li>
              <li><span class="text-green-500/50 mr-2">></span>Creación e integración de APIs REST con servicios backend y bases de datos NoSQL (MongoDB).</li>
              <li><span class="text-green-500/50 mr-2">></span>Implementación de interfaces responsivas y UX/UI adaptadas al cliente.</li>
            </ul>
          </div>

          <!-- B-metrix -->
          <div class="relative pl-8 border-l border-green-500/20 pb-10 group/job hover:border-green-500/50 transition-colors duration-300">
            <div class="absolute left-[-5px] top-1.5 w-2.5 h-2.5 rounded-full bg-black border-2 border-green-500/50 group-hover/job:bg-green-500 group-hover/job:border-green-500 transition-colors duration-300"></div>
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-1 mb-3">
              <div>
                <h4 data-i18n="exp3Title" class="text-white font-bold text-base">Programador Backend y Analista de Datos</h4>
                <p class="text-green-500 text-sm font-mono">B-metrix</p>
              </div>
              <span class="text-xs text-gray-500 font-mono whitespace-nowrap border border-green-500/20 px-2 py-0.5 h-max">Mar 2024 — Oct 2024</span>
            </div>
            <ul data-i18n="exp3Bullets" class="text-sm text-gray-400 flex flex-col gap-1.5">
              <li><span class="text-green-500/50 mr-2">></span>Diseño y desarrollo de scripts personalizados para automatizar procesos e interactuar con servicios web.</li>
              <li><span class="text-green-500/50 mr-2">></span>Implementación de soluciones de web scraping para extraer y estructurar datos para análisis.</li>
            </ul>
          </div>

          <!-- CaPREPA -->
          <div class="relative pl-8 border-l border-green-500/20 pb-10 group/job hover:border-green-500/50 transition-colors duration-300">
            <div class="absolute left-[-5px] top-1.5 w-2.5 h-2.5 rounded-full bg-black border-2 border-green-500/50 group-hover/job:bg-green-500 group-hover/job:border-green-500 transition-colors duration-300"></div>
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-1 mb-3">
              <div>
                <h4 data-i18n="exp4Title" class="text-white font-bold text-base">Becario en Sistemas y Programación</h4>
                <p class="text-green-500 text-sm font-mono">CaPREPA</p>
              </div>
              <span class="text-xs text-gray-500 font-mono whitespace-nowrap border border-green-500/20 px-2 py-0.5 h-max">Sep 2023 — Mar 2024</span>
            </div>
            <ul data-i18n="exp4Bullets" class="text-sm text-gray-400 flex flex-col gap-1.5">
              <li><span class="text-green-500/50 mr-2">></span>Desarrollo y ejecución de scripts para automatizar la extracción de datos y gestión de bases de datos.</li>
            </ul>
          </div>

          <!-- Reingeniería -->
          <div class="relative pl-8 border-l border-green-500/20 pb-0 group/job hover:border-green-500/50 transition-colors duration-300">
            <div class="absolute left-[-5px] top-1.5 w-2.5 h-2.5 rounded-full bg-black border-2 border-green-500/50 group-hover/job:bg-green-500 group-hover/job:border-green-500 transition-colors duration-300"></div>
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-1 mb-3">
              <div>
                <h4 data-i18n="exp5Title" class="text-white font-bold text-base">Analista de Datos</h4>
                <p class="text-green-500 text-sm font-mono">Reingeniería de Procesos, Cumplimientos y Consultoría</p>
              </div>
              <span class="text-xs text-gray-500 font-mono whitespace-nowrap border border-green-500/20 px-2 py-0.5 h-max">May 2022 — Jun 2023</span>
            </div>
            <ul data-i18n="exp5Bullets" class="text-sm text-gray-400 flex flex-col gap-1.5">
              <li><span class="text-green-500/50 mr-2">></span>Recopilación, procesamiento y visualización de grandes volúmenes de datos para toma de decisiones.</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="mt-20">
        <h3
          data-i18n="arsenalTitle"
          class="text-2xl font-bold text-white mb-8 border-b border-green-500/30 pb-4 inline-block pr-10 glitch-hover transition-colors duration-200 cursor-default"
        >
          > arsenal_técnico
        </h3>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <div
            class="border border-green-500/20 bg-gray-900/40 p-6 flex flex-col items-center justify-center gap-3 hover:border-green-400 hover:shadow-[0_0_15px_rgba(74,222,128,0.3)] hover:-translate-y-1 transition-all duration-300 cursor-default group"
          >
            <svg
              class="w-12 h-12 text-gray-600 group-hover:text-green-400 transition-colors duration-300"
              fill="currentColor"
              viewBox="16 16 32 32"
              ><path
                d="M31.885 16c-8.124 0-7.617 3.523-7.617 3.523l.01 3.65h7.752v1.095H21.197S16 23.678 16 31.876c0 8.196 4.537 7.906 4.537 7.906h2.708v-3.804s-.146-4.537 4.465-4.537h7.688s4.32.07 4.32-4.175v-7.019S40.374 16 31.885 16zm-4.275 2.454a1.394 1.394 0 1 1 0 2.79 1.393 1.393 0 0 1-1.395-1.395c0-.771.624-1.395 1.395-1.395z"
              ></path><path
                d="M32.115 47.833c8.124 0 7.617-3.523 7.617-3.523l-.01-3.65H31.97v-1.095h10.832S48 40.155 48 31.958c0-8.197-4.537-7.906-4.537-7.906h-2.708v3.803s.146 4.537-4.465 4.537h-7.688s-4.32-.07-4.32 4.175v7.019s-.656 4.247 7.833 4.247zm4.275-2.454a1.393 1.393 0 0 1-1.395-1.395 1.394 1.394 0 1 1 1.395 1.395z"
              ></path></svg
            >
            <span
              class="font-mono text-sm text-gray-400 group-hover:text-white transition-colors"
              >Python</span
            >
          </div>

          <div
            class="border border-green-500/20 bg-gray-900/40 p-6 flex flex-col items-center justify-center gap-3 hover:border-green-400 hover:shadow-[0_0_15px_rgba(74,222,128,0.3)] hover:-translate-y-1 transition-all duration-300 cursor-default group"
          >
            <svg
              class="w-12 h-12 text-gray-600 group-hover:text-green-400 transition-colors duration-300"
              fill="currentColor"
              viewBox="0 0 256 292"
              ><path
                d="M134.923 1.832c-4.344-2.443-9.502-2.443-13.846 0L6.787 67.801C2.443 70.244 0 74.859 0 79.745v132.208c0 4.887 2.715 9.502 6.787 11.945l114.29 65.968c4.344 2.444 9.502 2.444 13.846 0l114.29-65.968c4.344-2.443 6.787-7.058 6.787-11.945V79.745c0-4.886-2.715-9.501-6.787-11.944L134.923 1.832Z"
              ></path><path
                d="M249.485 67.8 134.65 1.833c-1.086-.542-2.443-1.085-3.529-1.357L2.443 220.912c1.086 1.357 2.444 2.443 3.8 3.258l114.834 65.968c3.258 1.9 7.059 2.443 10.588 1.357L252.47 70.515c-.815-1.086-1.9-1.9-2.986-2.714Z"
              ></path><path
                d="M249.756 223.898c3.258-1.9 5.701-5.158 6.787-8.687L130.579.204c-3.258-.543-6.787-.272-9.773 1.628L6.786 67.53l122.979 224.238c1.628-.272 3.529-.815 5.158-1.63l114.833-66.239Z"
              ></path></svg
            >
            <span
              class="font-mono text-sm text-gray-400 group-hover:text-white transition-colors"
              >Node.js</span
            >
          </div>

          <div
            class="border border-green-500/20 bg-gray-900/40 p-6 flex flex-col items-center justify-center gap-3 hover:border-green-400 hover:shadow-[0_0_15px_rgba(74,222,128,0.3)] hover:-translate-y-1 transition-all duration-300 cursor-default group"
          >
            <svg
              class="w-12 h-12 text-gray-600 group-hover:text-green-400 transition-colors duration-300"
              fill="currentColor"
              viewBox="0 0 256 256"
              ><path
                d="M128 0C57.33 0 0 57.33 0 128s57.33 128 128 128 128-57.33 128-128S198.67 0 128 0Zm-6.67 230.605v-80.288H76.699l64.128-124.922v80.288h42.966L121.33 230.605Z"
              ></path></svg
            >
            <span
              class="font-mono text-sm text-gray-400 group-hover:text-white transition-colors"
              >FastAPI</span
            >
          </div>

          <div
            class="border border-green-500/20 bg-gray-900/40 p-6 flex flex-col items-center justify-center gap-3 hover:border-green-400 hover:shadow-[0_0_15px_rgba(74,222,128,0.3)] hover:-translate-y-1 transition-all duration-300 cursor-default group"
          >
            <svg
              class="w-12 h-12 text-gray-600 group-hover:text-green-400 transition-colors duration-300"
              fill="currentColor"
