        </div>

        <section
          class="mt-24 mb-10 border border-green-500/30 bg-gray-900/60 p-1 relative overflow-hidden group shadow-[0_0_30px_rgba(0,0,0,0.5)]"
        >
          <div
            class="bg-black/50 px-4 py-2 border-b border-green-500/30 flex items-center justify-between"
          >
            <div class="flex items-center gap-2">
              <div
                class="w-3 h-3 rounded-full bg-red-500/80 border border-red-500"
              >
              </div>
              <div
                class="w-3 h-3 rounded-full bg-yellow-500/80 border border-yellow-500"
              >
              </div>
              <div
                class="w-3 h-3 rounded-full bg-green-500/80 border border-green-500"
              >
              </div>
            </div>
            <span class="text-xs text-gray-500 font-mono tracking-widest"
              >/usr/bin/contact_protocol</span
            >
            <div class="w-12"></div>
          </div>

          <div class="p-6 md:p-8 relative z-10">
            <p class="text-green-500 font-mono text-sm md:text-base mb-6">
              <span class="text-blue-400">root@visitor</span>:<span
                class="text-purple-400">~</span
              >$ ./initiate_contact.sh --target "Cristopher Meza"
              <br />
              <span data-i18n="contactEst" class="text-gray-400"
                >> Estableciendo conexión segura... [ OK ]</span
              >
              <br />
              <span data-i18n="contactParam" class="text-gray-400"
                >> Ingresando parámetros del mensaje:</span
              >
            </p>

            <form id="contact-form" class="flex flex-col gap-4 font-mono mt-4">
              <div class="flex flex-col md:flex-row gap-4">
                <div
                  class="w-full flex items-center bg-black border border-green-500/30 px-3 focus-within:border-green-400 focus-within:shadow-[0_0_10px_rgba(74,222,128,0.2)] transition-all"
                >
                  <span data-i18n="contactName" class="text-green-700 mr-2"
                    >> Nombre:</span
                  >
                  <input
                    type="text"
                    id="contact-name"
                    class="w-full bg-transparent py-3 text-green-400 focus:outline-none placeholder-green-900"
                    placeholder="_"
                    required
                  />
                </div>
                <div
                  class="w-full flex items-center bg-black border border-green-500/30 px-3 focus-within:border-green-400 focus-within:shadow-[0_0_10px_rgba(74,222,128,0.2)] transition-all"
                >
                  <span class="text-green-700 mr-2">> Email:</span>
                  <input
                    type="email"
                    id="contact-email"
                    class="w-full bg-transparent py-3 text-green-400 focus:outline-none placeholder-green-900"
                    placeholder="_"
                    required
                  />
                </div>
              </div>

              <div
                class="w-full flex items-start bg-black border border-green-500/30 px-3 py-3 focus-within:border-green-400 focus-within:shadow-[0_0_10px_rgba(74,222,128,0.2)] transition-all"
              >
                <span class="text-green-700 mr-2 mt-1">> Msg:</span>
                <textarea
                  id="contact-msg"
                  rows="4"
                  class="w-full bg-transparent text-green-400 focus:outline-none resize-none placeholder-green-900 mt-1"
                  placeholder="_"
                  required></textarea>
              </div>

              <button
                type="submit"
                class="mt-4 border border-green-500 px-6 py-3 w-full md:w-max hover:bg-green-500 hover:text-black transition-colors uppercase font-bold tracking-widest cursor-pointer self-end flex items-center justify-center gap-2"
              >
                <svg
                  class="w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg
                >
                <span data-i18n="contactBtn">[ EJECUTAR ENVÍO ]</span>
              </button>
            </form>
          </div>
        </section>
      </section>

      <footer
        class="mt-20 border-t border-green-500/30 pt-8 pb-12 font-mono text-xs md:text-sm text-gray-500 flex flex-col md:flex-row justify-between items-center gap-6 relative"
      >
        <div class="flex flex-col gap-2">
          <p class="text-green-700">
            > <span class="text-gray-400">sys.stats.get("movilidad");</span>
          </p>
          <p data-i18n="statEco" class="pl-4 text-green-500">
            "Racha continua en Ecobici: > 1 año 🚲"
          </p>

          <p class="text-green-700 mt-2">
            > <span class="text-gray-400">sys.hardware.status();</span>
          </p>
          <p data-i18n="statAstro" class="pl-4 text-green-500">
            "Proyector Astronauta: EN LÍNEA 🧑‍🚀"
          </p>
        </div>

        <div class="flex gap-6">
          <a
            href="https://github.com/CristopherAML"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-green-400 transition-colors">>> GitHub</a
          >
          <a
            href="https://www.linkedin.com/in/cristopher-leyva/"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-green-400 transition-colors">>> LinkedIn</a
          >
        </div>

        <div
          class="absolute bottom-2 right-2 md:bottom-4 md:right-4 opacity-30 hover:opacity-100 transition-opacity duration-300"
        >
          <span
            id="system-dog"
            class="cursor-pointer text-white text-lg"
            title="Mascota del Sistema"
          >
            ૮・ﻌ・ა
          </span>
        </div>
      </footer>
    </div>

    <script>
      import "../scripts/terminal.ts";
    </script>
  </body>
</html>
